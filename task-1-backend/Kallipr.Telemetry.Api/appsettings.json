{
  "ConnectionStrings": {
    "Sqlite": "telemetry.db"
  },
  "Telemetry": {
    "BatteryLowThreshold": 20
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
